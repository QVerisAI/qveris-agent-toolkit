{
  "name": "@qverisai/qveris",
  "version": "2026.6.4",
  "description": "OpenClaw QVeris plugin — capability discovery, tool inspection, and tool calling",
  "type": "module",
  "files": [
    "index.ts",
    "dist/**/*.js",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "src/config.ts",
    "src/qveris-cache.ts",
    "src/qveris-client.ts",
    "src/qveris-errors.ts",
    "src/qveris-materialization.ts",
    "src/qveris-tools.ts",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "check:pack": "node scripts/check-pack.mjs",
    "prepack": "npm run build",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check \"src/**/*.ts\" \"index.ts\" \"scripts/**/*.mjs\"",
    "lint:fix": "eslint . --fix && prettier --write \"src/**/*.ts\" \"index.ts\" \"scripts/**/*.mjs\""
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.50"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "openclaw": "^2026.6.4",
    "prettier": "^3.9.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.3.24"
    },
    "install": {
      "npmSpec": "@qverisai/qveris",
      "minHostVersion": ">=2026.3.22"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
