{
  "name": "@qverisai/cli",
  "version": "0.7.0",
  "description": "QVeris CLI for agent capability discovery, inspection, calling, and audit",
  "type": "module",
  "bin": {
    "qveris": "./bin/qveris.mjs"
  },
  "scripts": {
    "test": "node --test",
    "lint": "eslint . && prettier --check \"src/**/*.mjs\" \"bin/**/*.mjs\" \"test/**/*.mjs\"",
    "lint:fix": "eslint . --fix && prettier --write \"src/**/*.mjs\" \"bin/**/*.mjs\" \"test/**/*.mjs\""
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "CHANGELOG.md"
  ],
  "keywords": [
    "qveris",
    "cli",
    "api",
    "agent",
    "capabilities",
    "tool-calling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/QVerisAI/qveris-agent-toolkit",
    "directory": "packages/cli"
  },
  "homepage": "https://qveris.ai",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
